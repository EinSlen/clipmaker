# Groq (LLM gratuit — recommandé). Crée une clé sur https://console.groq.com/keys
GROQ_API_KEY=
# Modèle Groq par défaut (rapide et bon en français)
GROQ_MODEL=llama-3.3-70b-versatile

# Optionnel : override Claude (premium). Laissé vide → Groq utilisé.
ANTHROPIC_API_KEY=

# Binaire Python utilisé pour piloter TiktokAutoUploader (login + upload "cookies")
PYTHON_BIN=python

# YouTube Data API v3 (officielle, gratuite). Indispensable sur hébergeur cloud
# (Render, Fly, etc.) car YouTube bloque les IPs datacenter pour yt-dlp / Invidious.
# Crée un projet sur https://console.cloud.google.com/, active "YouTube Data API v3",
# génère une API key.
YOUTUBE_API_KEY=

# Liste custom d'instances Invidious (séparées par virgules) — utilisé en fallback
# si YOUTUBE_API_KEY n'est pas définie. Vide = liste par défaut.
INVIDIOUS_INSTANCES=
