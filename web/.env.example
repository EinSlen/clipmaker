# Groq (LLM gratuit — recommandé). Crée une clé sur https://console.groq.com/keys
GROQ_API_KEY=
# Modèle Groq par défaut (rapide et bon en français)
GROQ_MODEL=llama-3.3-70b-versatile

# Optionnel : override Claude (premium). Laissé vide → Groq utilisé.
ANTHROPIC_API_KEY=

# Binaire Python utilisé pour piloter TiktokAutoUploader (login + upload "cookies")
PYTHON_BIN=python
